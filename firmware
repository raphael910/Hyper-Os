                d.innerHTML = `<h1>ACCES REFUSE</h1><p>PRIVILÈGES INSUFFISANTS</p>`;
                return d;
            }
            d.className = 'admin-dash'; d.style.padding = '20px'; d.style.overflowY='auto'; d.style.height='100%';
            d.innerHTML = `
                <h2 style="color:var(--primary);">PANNEAU DE CONTRÔLE</h2>
                <div style="background:rgba(255,255,255,0.05); padding:15px; margin:15px 0;">
                    <h3>BASE UTILISATEURS (${DB.data.users.length})</h3>
                    <div style="max-height:200px; overflow-y:auto; margin-top:10px;">
                        ${DB.data.users.map(u => `
                            <div style="display:flex; justify-content:space-between; padding:8px; border-bottom:1px solid #333; font-size:11px;">
                                <span>${u.name} (${u.ip}) - ${u.role}</span>
                                <span style="color:var(--primary);">${u.money} CR</span>
                            </div>
                        `).join('')}
                    </div>
                </div>
                <div style="background:rgba(255,255,255,0.05); padding:15px;">
                    <h3>LOGS D'ACTIVITÉ</h3>
                    <div style="font-family:'JetBrains Mono'; font-size:10px; max-height:150px; overflow-y:auto; margin-top:10px;">
                        ${DB.data.hacks.map(l => `<div>[${l.t}] ${l.m}</div>`).join('')}
                    </div>
                </div>
            `;
            return d;
        }
    }
};

// Lancement du système
window.onload = () => Sys.init();
</script>
</body>
</html>
