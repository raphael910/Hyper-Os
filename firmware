const WindowManager = {
    zIndex: 100,
    open(appId, title, renderFn, w=700, h=500) {
        const id = 'win_' + Date.now();
        this.zIndex++;
        const win = document.createElement('div');
        win.className = 'window';
        win.id = id;
        win.style.width = w+'px'; win.style.height = h+'px';
        win.style.top = (50+(this.zIndex%20)*15)+'px'; win.style.left = (50+(this.zIndex%20)*15)+'px';
        win.style.zIndex = this.zIndex;
        
        win.innerHTML = `
            <div class="win-header" onmousedown="WindowManager.focus('${id}')">
                <span class="win-title">${title}</span>
                <div class="win-controls">
                    <button class="win-btn win-min" onclick="WindowManager.minimize('${id}')"></button>
                    <button class="win-btn win-max" onclick="WindowManager.maximize('${id}')"></button>
                    <button class="win-btn win-close" onclick="WindowManager.close('${id}')"></button>
                </div>
            </div>
            <div class="win-body" id="body-${id}"></div>
            <div class="resize-handle" onmousedown="WindowManager.initResize(event, '${id}')"></div>
        `;
        document.getElementById('desktop-area').appendChild(win);
        document.getElementById(`body-${id}`).appendChild(renderFn(id));
        this.addTaskbar(id, appId, title);
        this.makeDraggable(win);
    },
    close(id) { document.getElementById(id)?.remove(); document.getElementById('tb-'+id)?.remove(); },
    minimize(id) { document.getElementById(id).classList.add('minimized'); document.getElementById('tb-'+id).classList.remove('active'); },
    maximize(id) { document.getElementById(id).classList.toggle('maximized'); },
    focus(id) {
        this.zIndex++;
        const w = document.getElementById(id);
        if(w) w.style.zIndex = this.zIndex;
        document.querySelectorAll('.tb-item').forEach(e => e.classList.remove('active'));
        const tb = document.getElementById('tb-'+id);
        if(tb) tb.classList.add('active');
    },
    addTaskbar(id, app, title) {
        const tb = document.getElementById('tb-open-apps');
        const el = document.createElement('div');
        el.className = 'tb-item active'; el.id = 'tb-'+id;
        el.innerText = APPS[app].icon || app[0];
        el.title = title;
        el.onclick = () => {
            const w = document.getElementById(id);
            if(w.classList.contains('minimized')) { w.classList.remove('minimized'); this.focus(id); }
            else if(w.style.zIndex != this.zIndex) this.focus(id);
            else this.minimize(id);
        };
        tb.appendChild(el);
    },
    makeDraggable(el) {
        const h = el.querySelector('.win-header');
        let isD=false, sx, sy, ix, iy;
        h.onmousedown = (e) => { if(e.target.tagName==='BUTTON')return; isD=true; sx=e.clientX; sy=e.clientY; ix=el.offsetLeft; iy=el.offsetTop; this.focus(el.id); };
        window.onmousemove = (e) => { if(!isD)return; el.style.left=(ix+e.clientX-sx)+'px'; el.style.top=(iy+e.clientY-sy)+'px'; };
        window.onmouseup = () => isD=false;
    },
    initResize(e, id) {
        e.preventDefault();
        const w = document.getElementById(id);
        const sx=e.clientX, sy=e.clientY, sw=parseInt(w.style.width), sh=parseInt(w.style.height);
        const move = (ev) => { w.style.width=(sw+ev.clientX-sx)+'px'; w.style.height=(sh+ev.clientY-sy)+'px'; };
        const stop = () => { document.removeEventListener('mousemove',move); document.removeEventListener('mouseup',stop); };
        document.addEventListener('mousemove',move); document.addEventListener('mouseup',stop);
    }
};

